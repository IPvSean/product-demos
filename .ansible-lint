---
profile: production
offline: true

skip_list:
  - "galaxy[no-changelog]"
  - "var-naming[no-role-prefix]"

warn_list:
  - "fqcn[canonical]"
  - "jinja[invalid]"

exclude_paths:
  - collections/ansible_collections/demo/compliance/roles/
  - roles/redhatofficial.*
  - .github/
  - execution_environments/ee_contexts/
  - .patch_demo_export/

mock_modules:
  - amazon.aws.aws_caller_info
  - amazon.aws.ec2_eip
  - amazon.aws.ec2_eip_info
  - amazon.aws.ec2_eni
  - amazon.aws.ec2_eni_info
  - amazon.aws.ec2_instance
  - amazon.aws.ec2_instance_info
  - amazon.aws.ec2_key
  - amazon.aws.ec2_key_info
  - amazon.aws.ec2_security_group
  - amazon.aws.ec2_security_group_info
  - amazon.aws.ec2_tag
  - amazon.aws.ec2_vpc_igw
  - amazon.aws.ec2_vpc_igw_info
  - amazon.aws.ec2_vpc_net
  - amazon.aws.ec2_vpc_net_info
  - amazon.aws.ec2_vpc_route_table
  - amazon.aws.ec2_vpc_route_table_info
  - amazon.aws.ec2_vpc_subnet
  - amazon.aws.ec2_vpc_subnet_info
  - amazon.aws.s3_bucket
  - amazon.aws.s3_object
  - amazon.aws.s3_object_info
  - ansible.controller.credential
  - ansible.posix.at
  - ansible.posix.authorized_key
  - ansible.posix.firewalld
  - ansible.posix.seboolean
  - ansible.utils.fact_diff
  - ansible.windows.win_command
  - ansible.windows.win_copy
  - ansible.windows.win_dns_client
  - ansible.windows.win_dsc
  - ansible.windows.win_feature
  - ansible.windows.win_hostname
  - ansible.windows.win_ping
  - ansible.windows.win_powershell
  - ansible.windows.win_reboot
  - ansible.windows.win_service
  - ansible.windows.win_shell
  - ansible.windows.win_template
  - ansible.windows.win_updates
  - ansible.windows.win_user
  - chocolatey.chocolatey.win_chocolatey
  - cisco.ios.ios_facts
  - cisco.iosxr.iosxr_facts
  - cisco.nxos.nxos_facts
  - community.aws.s3_sync
  - community.aws.s3_website
  - community.general.redhat_subscription
  - community.general.rhsm_repository
  - community.windows.win_psmodule
  - containers.podman.podman_container
  - kubernetes.core.k8s
  - kubernetes.core.k8s_info
  - microsoft.ad.domain
  - microsoft.ad.group
  - microsoft.ad.membership
  - microsoft.ad.ou
  - microsoft.ad.user
  - paloaltonetworks.panos.panos_commit_firewall
  - paloaltonetworks.panos.panos_interface
  - paloaltonetworks.panos.panos_management_profile
  - paloaltonetworks.panos.panos_nat_rule2
  - paloaltonetworks.panos.panos_security_rule
  - paloaltonetworks.panos.panos_zone
  - redhat.openshift.k8s
  - redhat.openshift_virtualization.kubevirt_vm_info
  - redhat.satellite.content_view_version
  - redhat.satellite.scap_tailoring_file
  - redhat.satellite.subscription_manifest
  - seboolean
  - servicenow.itsm.api
  - servicenow.itsm.api_info
  - servicenow.itsm.configuration_item
  - servicenow.itsm.configuration_item_info

mock_roles:
  - redhat.insights.compliance
  - redhat.insights.insights_client
